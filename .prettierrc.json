{
  "$schema": "https://json.schemastore.org/prettierrc",
  "semi": false,
  "tabWidth": 2,
  "singleQuote": true,
  "printWidth": 100,
  "trailingComma": "none",
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": ["^@form-magic/core", "^[./]"],
  "importOrderSeparation": true,
  "importOrderMergeDuplicateImports": true
}
