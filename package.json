{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -C play/vue-form-craft dev",
    "build": "pnpm -C packages/vue-form-craft build",
    "small-v": "pnpm -C packages/vue-form-craft v",
    "release": "pnpm -C packages/vue-form-craft release",
    "dev:antd": "pnpm -C play/ant-design dev",
    "build:antd": "pnpm -C play/ant-design build",
    "docs:dev": "pnpm -C docs dev",
    "docs:build": "pnpm -C docs build",
    "docs:preview": "pnpm -C docs preview",
    "docs:release": "node releaseDocs.js",
    "change": "changeset",
    "change-v": "changeset version",
    "test": "vitest --config ./vitest.config.ts",
    "clear": "find . -type d -name 'node_modules' -exec rm -rf {} \\;"
  },
  "dependencies": {
    "@vue-form-craft/core": "workspace:*",
    "@vue-form-craft/styles": "workspace:*",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.6.2",
    "dotenv": "^17.2.2",
    "element-plus": "^2.8.3",
    "jsoneditor": "^10.3.0",
    "lodash": "^4.17.21",
    "shiki": "^1.21.0",
    "vue": "^3.5.8",
    "vue-element-plus-x": "^1.3.7",
    "vue-form-craft": "workspace:*",
    "vuedraggable-es-fix": "^1.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@ianvs/prettier-plugin-sort-imports": "^4.6.2",
    "@rushstack/eslint-patch": "^1.3.3",
    "@tsconfig/node20": "^20.1.2",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.5",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vitejs/plugin-vue-jsx": "^4.1.0",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/shared": "^3.4.38",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.0.3",
    "sass": "~1.32.6",
    "typescript": "~5.3.0",
    "vite": "^5.0.10",
    "vite-plugin-dts": "^3.7.3",
    "vite-plugin-libcss": "^1.1.1",
    "vitest": "^2.1.5"
  }
